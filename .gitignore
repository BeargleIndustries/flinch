# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# IDE
.vscode/
.idea/

# Database
data/*.db
data/*.db-shm
data/*.db-wal

# Probe content — publish tool + example format, not research probes
flinch/probes/*.yaml
flinch/probes/*.md
flinch/probes/*.json
!flinch/probes/.gitkeep
!flinch/probes/example-probes.md

# Environment
.env

# OS
.DS_Store
Thumbs.db

# OMC state
.omc/

# Internal docs
AUDIT.md

# User data
sessions/

# Rust / Cargo / Tauri
target/
src-tauri/target/
src-tauri/gen/
**/*.rs.bk

# Bundled build-time resources (fetched/built by scripts/bundle-resources.py)
src-tauri/resources/*.tar.gz
src-tauri/resources/*.whl

# Tauri dev-run scratch DB (appears when running cargo tauri dev)
src-tauri/data/

# Installer outputs
*.exe
*.msi
*.nsis

# Sidecar bootstrap markers
sidecar.hash
crash-*.log

# Launcher state (per-clone, lives in %LOCALAPPDATA%)
.flinch-bootstrap.json
