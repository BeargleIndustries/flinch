# Flinch — API Keys
# Copy this file to .env and fill in your keys for the models you want to test.

# Anthropic (Claude models) — REQUIRED for coach + classifier + Claude targets
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (GPT models) — optional, only needed if testing OpenAI targets
OPENAI_API_KEY=your-openai-api-key-here

# Google (Gemini models) — optional, only needed if testing Gemini targets
GOOGLE_API_KEY=your-google-api-key-here

# xAI (Grok models) — optional, only needed if testing Grok targets
XAI_API_KEY=your-xai-api-key-here

# Together AI (Llama models via Together) — optional, only needed if testing Llama targets
TOGETHER_API_KEY=your-together-api-key-here
